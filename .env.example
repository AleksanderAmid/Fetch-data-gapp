# Supabase connection (service role key bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# API key for securing sync/auth endpoints (must match GOLDADAM_SYNC_API_KEY in route-analysis)
SYNC_API_KEY=your-random-secret-key-here

# Port (default 3000)
PORT=3000
